# Copy to ".env" (gitignored) and fill in what you need.
# DEFAULTS ARE $0: with no keys at all, the app runs fully on Mock adapters,
# and the LLM falls back to the offline "canned" brain.

# ---- Master switches --------------------------------------------------------
USE_MOCKS=true            # true => every integration uses its Mock adapter
LLM_BACKEND=auto          # auto | mistral | claude | ollama | canned
                          # auto => free Mistral -> Claude -> canned (offline, $0)

# ---- LLM brain --------------------------------------------------------------
# Mistral free "Experiment" tier supports tool-use => a real brain at $0.
# Grab a free key at https://console.mistral.ai (no credit card).
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_MODEL_REALTIME=mistral-small-latest  # lower latency for live calls
# Claude — premium swap; small per-call cost.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_REALTIME=claude-sonnet-4-6
# Local Ollama — truly $0/offline (use when it's stable):
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b

# ---- Local speech (no keys needed) -----------------------------------------
WHISPER_MODEL=base.en
PIPER_VOICE=en_US-amy-medium

# ---- Optional: real Zoho CRM (only used when USE_MOCKS=false + creds set) ----
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# ---- Optional: real Ceipal ATS ---------------------------------------------
CEIPAL_EMAIL=
CEIPAL_PASSWORD=
CEIPAL_API_KEY=

# ---- Optional: real Vonage telephony (for a live PSTN demo) -----------------
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY_PATH=
VONAGE_NUMBER=
PUBLIC_BASE_URL=          # e.g. https://<id>.ngrok-free.app  (webhook target)

# ---- Optional: real email via SMTP -----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ai-agent@example.com

# ---- App --------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000
